# --- Vercel serverless (set in Vercel → Settings → Environment Variables) ---
# Get a key at https://resend.com/api-keys — paste ONLY in Vercel (never commit real keys).
RESEND_API_KEY=

# Optional. If unset, the API uses Resend’s test sender `onboarding@resend.dev`.
# Production: use a verified domain address, e.g. Date Idea <notify@yourdomain.com>
# NOTIFY_FROM_EMAIL=

# Optional override (defaults to kostaskoukianakis72@gmail.com in api/notify-harbor-choice.ts if unset)
# NOTIFY_TO_EMAIL=kostaskoukianakis72@gmail.com

# Optional: lock POSTs to your site only (comma-separated). Include dev if you use `vercel dev`:
# NOTIFY_ALLOWED_ORIGINS=https://your-project.vercel.app,http://localhost:3000

# --- Local Vite only (optional): if `npm run dev` cannot reach /api, point to a preview deployment:
# VITE_NOTIFY_API_URL=https://your-project.vercel.app
